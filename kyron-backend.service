[Unit]
Description=Kyron Medical FastAPI Backend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/kyron-medical/backend
EnvironmentFile=/home/ubuntu/kyron-medical/backend/.env
ExecStart=/home/ubuntu/kyron-medical/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
